---
import "../styles/reset.css";
import "../styles/styles.css";
---

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&family=Open+Sans:ital,wght@0,300..800;1,300..800&family=Ubuntu:ital,wght@0,300;0,400;0,500;0,700;1,300;1,400;1,500;1,700&display=swap"
        rel="stylesheet">
    <title>Steamfolio</title>
</head>

<body>
    <div class="profile-container">
        <header class="profile-header">
            <div class="profile-header-left">
                <div class="profile-frame">
                    <img src="/assets/portrait.jpg" alt="Una imagen mia">
                </div>
                <div class="profile-info">
                    <div>
                        <h2 class="profile-name">Alejandro Cortés</h2>
                        <div class="web-developer">
                            <h3>Desarrollador Frontend</h3>
                            <div class="profile-location">
                                <img src="/assets/es.svg" alt="Bandera de España" width="3rem">
                                <p>Granada, España</p>
                            </div>
                        </div>
                    </div>

                    <div class="social-media">
                        <a href="https://www.linkedin.com/in/alejandro-cort%C3%A9s-moreno/" target="_blank"
                            rel="noopener noreferrer">
                            <img src="/assets/social-media/linkedin.svg" alt="LinkedIn" class="icon" />
                        </a>
                        <a class="social-media" href="https://github.com/acortesmoreno" target="_blank"
                            rel="noopener noreferrer">
                            <img src="/assets/technologies/github.svg" alt="GitHub" class="icon" />
                        </a>
                    </div>
                    <p>Desarrollador frontend con experiencia creando aplicaciones web que resuelven problemas reales.
                        He llevado proyectos desde la conceptualización hasta producción con usuarios activos.</p>
                    <a href="/element-snap" class="extensions-link">Extensiones →</a>
                </div>
            </div>
            <div class="profile-header-right">
                <div class="profile-level">
                    <h3>Nivel</h3>
                    <p class="profile-level-number">74</p>
                </div>
                <div>
                    <a href="mailto:lacrimadev@gmail.com">
                        <button>Enviar un mensaje</button>
                    </a>
                    <a href="https://wa.me/34697687209" target="_blank">
                        <button>
                            WhatsApp
                            <img src="https://community.fastly.steamstatic.com/public/images/profile/profile_action_dropdown.png"
                                alt="Icono de flecha mirando hacia abajo">
                        </button>

                    </a>
                </div>

            </div>
        </header>

        <div class="profile-content">
            <div class="profile-content-sections">
                <section class="profile-projects">
                    <header>
                        <h2>Expositor de proyectos</h2>
                    </header>
                    <div class="project-container">
                        <div class="project-card">
                            <a href="https://nutriplo.com" target="_blank" rel="noopener noreferrer">
                                <img src="/assets/projects-screenshots/nutriplo.webp" alt="Imagen de nutriplo">
                            </a>
                            <div class="project-info">
                                <a href="https://nutriplo.com" target="_blank" rel="noopener noreferrer">
                                    <img src="/assets/projects-screenshots/nutriplo-logo.webp" alt="Nutriplo" class="project-logo">
                                </a>
                                <p>Plataforma SaaS para profesionales de la nutrición con gestión de pacientes,
                                    evaluación clínica y generación de informes PDF.</p>
                            </div>
                        </div>
                        <div class="project-footer">
                            <p>Tecnologías usadas 12 de 16</p>
                            <div class="project-technologies">
                                <object data="/assets/technologies/ts.svg" type="image/svg+xml" class="icon"></object>
                                <object data="/assets/technologies/react.svg" type="image/svg+xml"
                                    class="icon"></object>
                                <object data="/assets/technologies/tailwind.svg" type="image/svg+xml"
                                    class="icon"></object>
                                <object data="/assets/technologies/vite.svg" type="image/svg+xml"
                                    class="icon"></object>
                                <object data="/assets/technologies/node.svg" type="image/svg+xml"
                                    class="icon"></object>
                                <object data="/assets/technologies/postgresql.svg" type="image/svg+xml"
                                    class="icon"></object>
                                <object data="/assets/technologies/express.svg" type="image/svg+xml"
                                    class="icon"></object>
                                <object data="/assets/technologies/git.svg" type="image/svg+xml"
                                    class="icon"></object>
                                <object data="/assets/technologies/github.svg" type="image/svg+xml"
                                    class="icon"></object>
                                <object data="/assets/technologies/markdown.svg" type="image/svg+xml"
                                    class="icon"></object>
                                <object data="/assets/technologies/supabase.svg" type="image/svg+xml"
                                    class="icon"></object>
                                <object data="/assets/technologies/prisma.svg" type="image/svg+xml"
                                    class="icon"></object>
                            </div>
                        </div>
                    </div>
                    <div class="project-container">
                        <div class="project-card">
                            <a href="https://nutri.tools" target="_blank" rel="noopener noreferrer">
                                <img src="/assets/projects-screenshots/nutritools.webp" alt="Imagen de Nutritools">
                            </a>
                            <div class="project-info">
                                <a href="https://nutri.tools" target="_blank" rel="noopener noreferrer">
                                    <img src="/assets/projects-screenshots/nutritools-logo.webp" alt="Nutritools" class="project-logo">
                                </a>
                                <p>Calculadora clínica de nutrición con 25+ calculadoras validadas científicamente,
                                    evaluación inteligente por paciente y generación de informes PDF profesionales.</p>
                            </div>
                        </div>
                        <div class="project-footer">
                            <p>Tecnologías usadas 12 de 16</p>
                            <div class="project-technologies">
                                <object data="/assets/technologies/ts.svg" type="image/svg+xml" class="icon"></object>
                                <object data="/assets/technologies/react.svg" type="image/svg+xml" class="icon"></object>
                                <object data="/assets/technologies/tailwind.svg" type="image/svg+xml" class="icon"></object>
                                <object data="/assets/technologies/vite.svg" type="image/svg+xml" class="icon"></object>
                                <object data="/assets/technologies/node.svg" type="image/svg+xml" class="icon"></object>
                                <object data="/assets/technologies/postgresql.svg" type="image/svg+xml" class="icon"></object>
                                <object data="/assets/technologies/express.svg" type="image/svg+xml" class="icon"></object>
                                <object data="/assets/technologies/git.svg" type="image/svg+xml" class="icon"></object>
                                <object data="/assets/technologies/github.svg" type="image/svg+xml" class="icon"></object>
                                <object data="/assets/technologies/markdown.svg" type="image/svg+xml" class="icon"></object>
                                <object data="/assets/technologies/supabase.svg" type="image/svg+xml" class="icon"></object>
                                <object data="/assets/technologies/prisma.svg" type="image/svg+xml" class="icon"></object>
                            </div>
                        </div>
                    </div>
                </section>
                <section class="profile-projects">
                    <header>
                        <h2>Extensiones</h2>
                    </header>
                    <div class="project-container">
                        <div class="project-card">
                            <a href="/element-snap" rel="noopener noreferrer">
                                <img src="/assets/projects-screenshots/browser-extension-element-snap.webp" alt="Element Snap preview" class="project-card-img-contain">
                            </a>
                            <div class="project-info">
                                <a href="/element-snap">
                                    <h3>Element Snap</h3>
                                </a>
                                <p>Captura cualquier elemento visual de una página web con un clic. Exporta como PNG, JPEG o WebP con fondo transparente, escala retina y sombras incluidas.</p>
                            </div>
                        </div>
                        <div class="project-footer">
                            <p>Tecnologías usadas 4 de 16</p>
                            <div class="project-technologies">
                                <object data="/assets/technologies/ts.svg" type="image/svg+xml" class="icon"></object>
                                <object data="/assets/technologies/react.svg" type="image/svg+xml" class="icon"></object>
                                <object data="/assets/technologies/tailwind.svg" type="image/svg+xml" class="icon"></object>
                                <object data="/assets/technologies/vite.svg" type="image/svg+xml" class="icon"></object>
                            </div>
                        </div>
                    </div>
                </section>
                <section class="profile-projects">
                    <header>
                        <h2>Experiencia laboral</h2>
                    </header>
                    <div class="project-container">
                        <div class="project-card">
                            <a href="https://nutriclub.cl" target="_blank" rel="noopener noreferrer">
                                <img src="/assets/projects-screenshots/nutriclub.webp" alt="Imagen de nutriclub">
                            </a>
                            <div class="project-info">
                                <a href="https://nutriclub.cl" target="_blank" rel="noopener noreferrer">
                                    <h3>Nutriclub</h3>
                                </a>
                                <p>Una tienda digital para profesionales y estudiantes de nutrición. Fue un proyecto que
                                    me enseñó mucho sobre cómo estructurar catálogos de productos digitales y crear una
                                    experiencia de compra sencilla, clara y confiable.</p>
                            </div>
                        </div>
                        <div class="project-footer">
                            <p>Tecnologías usadas 2 de 16</p>
                            <div class="project-technologies">
                                <object data="/assets/technologies/wordpress.svg" type="image/svg+xml"
                                    class="icon"></object>
                                <object data="/assets/technologies/elementor.svg" type="image/svg+xml"
                                    class="icon"></object>
                            </div>
                        </div>
                    </div>
                    <div class="project-container">
                        <div class="project-card">
                            <a href="https://nativobjj.com" target="_blank" rel="noopener noreferrer">
                                <img src="/assets/projects-screenshots/nativobjj.webp" alt="Imagen de nativobjj">
                            </a>
                            <div class="project-info">
                                <a href="https://nativobjj.com" target="_blank" rel="noopener noreferrer">
                                    <h3>Nativo BJJ</h3>
                                </a>
                                <p>Una tienda online especializada en equipamiento para jiu-jitsu brasileño. Con este
                                    proyecto aprendí a manejar la lógica de un e-commerce físico, desde la organización
                                    de productos hasta la importancia de transmitir la esencia de una marca ligada a una
                                    comunidad deportiva.</p>
                            </div>
                        </div>
                        <div class="project-footer">
                            <p>Tecnologías usadas 1 de 16</p>
                            <div class="project-technologies">
                                <object data="/assets/technologies/wordpress.svg" type="image/svg+xml"
                                    class="icon"></object>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
            <aside>
                <section>
                    <header id="aside-header" class="aside-header">
                        <p>Sin Conexión</p>
                        <p>Última Conexión: ayer</p>
                    </header>
                    <div class="aside-body">
                        <div class="badges">
                            <p>Tecnologías <span>16</span></p>
                            <div class="badges-container">
                                <object data="/assets/technologies/html5.svg" type="image/svg+xml"
                                    class="icon"></object>
                                <object data="/assets/technologies/css.svg" type="image/svg+xml"
                                    class="icon"></object>
                                <object data="/assets/technologies/js.svg" type="image/svg+xml"
                                    class="icon"></object>
                                <object data="/assets/technologies/ts.svg" type="image/svg+xml"
                                    class="icon"></object>
                                <object data="/assets/technologies/react.svg" type="image/svg+xml"
                                    class="icon"></object>
                                <object data="/assets/technologies/tailwind.svg" type="image/svg+xml"
                                    class="icon"></object>
                                <object data="/assets/technologies/sass.svg" type="image/svg+xml"
                                    class="icon"></object>
                                <object data="/assets/technologies/node.svg" type="image/svg+xml"
                                    class="icon"></object>
                                <object data="/assets/technologies/vite.svg" type="image/svg+xml"
                                    class="icon"></object>
                                <object data="/assets/technologies/postgresql.svg" type="image/svg+xml"
                                    class="icon"></object>
                                <object data="/assets/technologies/express.svg" type="image/svg+xml"
                                    class="icon"></object>
                                <object data="/assets/technologies/git.svg" type="image/svg+xml"
                                    class="icon"></object>
                                <object data="/assets/technologies/github.svg" type="image/svg+xml"
                                    class="icon"></object>
                                <object data="/assets/technologies/markdown.svg" type="image/svg+xml"
                                    class="icon"></object>
                                <object data="/assets/technologies/wordpress.svg" type="image/svg+xml"
                                    class="icon"></object>
                                <object data="/assets/technologies/elementor.svg" type="image/svg+xml"
                                    class="icon"></object>
                            </div>
                        </div>
                        <div class="other-tools">
                            <p>Otras herramientas <span>7</span></p>
                            <div class="other-tools-container">
                                <object data="/assets/technologies/vsc.svg" type="image/svg+xml"
                                    class="icon"></object>
                                <object data="/assets/technologies/windsurf.svg" type="image/svg+xml"
                                    class="icon"></object>
                                <object data="/assets/technologies/trello.svg" type="image/svg+xml"
                                    class="icon"></object>
                                <object data="/assets/technologies/linux.svg" type="image/svg+xml"
                                    class="icon"></object>
                                <object data="/assets/technologies/vercel.svg" type="image/svg+xml"
                                    class="icon"></object>
                                <object data="/assets/technologies/railway.svg" type="image/svg+xml"
                                    class="icon"></object>
                                <object data="/assets/technologies/supabase.svg" type="image/svg+xml"
                                    class="icon"></object>
                            </div>
                        </div>
                    </div>

                </section>
            </aside>
        </div>
    </div>
    <footer>
        <p><i>Sí, parece Steam </i>👀. <i>no me demandes Valve </i>😢.</p>
    </footer>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const asideHeader = document.getElementById('aside-header');

            const getRandomNumber = () => Math.floor(Math.random() * 11);
            const isPair = (n) => n % 2 === 0;

            const changeProfileConection = () => {
                const F = isPair(getRandomNumber());

                if (F) {
                    asideHeader.innerHTML = `
                    <div class="online">
                    <div class="online-circle"></div>
                    <p class="online-text">En Linea</p>
                    </div>
                `;
                    return;
                }
            }
            changeProfileConection();
        })
    </script>
</body>

</html>
