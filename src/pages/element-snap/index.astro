---
import BaseLayout from "../../layouts/BaseLayout.astro";
import "../../styles/element-snap.css";
---

<BaseLayout
  title="Element Snap — Capture web elements as images"
  description="Element Snap is a Chrome extension that lets you capture any visual element from a webpage as a high-quality PNG, JPEG, or WebP image."
  canonical="https://lacrima.dev/element-snap/"
>
  <div class="es">
    <nav class="es-nav">
      <a href="/" class="es-nav-back">← lacrima.dev</a>
    </nav>

    <section class="es-hero">
      <div class="es-hero-bg">
        <img src="/assets/projects-screenshots/element-snap-hero.png" alt="" />
      </div>
      <div class="es-hero-content">
        <img src="/assets/projects-screenshots/element-snap-logo.png" alt="Element Snap logo" class="es-logo" />
        <h1>Element Snap</h1>
        <p>Point, click, capture. Turn any element on a webpage into a high-quality image.</p>
        <a href="https://chromewebstore.google.com/detail/element-snap" class="es-cta" target="_blank" rel="noopener noreferrer">
          Add to Chrome — it's free
        </a>
      </div>
    </section>

    <section class="es-section">
      <h2>How it works</h2>
      <div class="es-steps">
        <div class="es-step">
          <span class="es-step-num">1</span>
          <div>
            <strong>Select</strong>
            <p>Click the toolbar icon, then hover any element to preview it.</p>
          </div>
        </div>
        <div class="es-step">
          <span class="es-step-num">2</span>
          <div>
            <strong>Configure</strong>
            <p>Choose format, scale, background, and margin from the floating toolbar.</p>
          </div>
        </div>
        <div class="es-step">
          <span class="es-step-num">3</span>
          <div>
            <strong>Capture</strong>
            <p>Download the image or copy it straight to your clipboard.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="es-section">
      <h2>Features</h2>
      <div class="es-grid">
        <div class="es-card">
          <h3>Multi-format export</h3>
          <p>PNG for lossless quality, JPEG or WebP for smaller files. Transparent or white background.</p>
        </div>
        <div class="es-card">
          <h3>Retina-ready scaling</h3>
          <p>Capture at 1x, 2x, 3x, or 4x. Sharp on any display from standard monitors to 5K Retina.</p>
        </div>
        <div class="es-card">
          <h3>Shadow-aware</h3>
          <p>Automatically detects and includes box-shadow, drop-shadow, and text-shadow with proper padding.</p>
        </div>
        <div class="es-card">
          <h3>Clipboard copy</h3>
          <p>Copy directly to clipboard. Paste into Figma, Slack, Notion, or any app — no download needed.</p>
        </div>
        <div class="es-card">
          <h3>Batch capture</h3>
          <p>Detect and download all similar elements on a page at once. Great for design systems.</p>
        </div>
        <div class="es-card">
          <h3>Custom filenames</h3>
          <p>Templates like <code>{'{tag}-{page}-{date}'}</code> to organize captures automatically.</p>
        </div>
      </div>
    </section>

    <section class="es-section es-privacy">
      <h2>Your data stays on your machine</h2>
      <p>Every capture is processed locally in your browser. No images, page content, or browsing data ever leave your device.</p>
      <a href="/element-snap/privacy">Read the full privacy policy →</a>
    </section>

    <footer class="es-footer">
      <a href="mailto:lacrimadev@gmail.com">lacrimadev@gmail.com</a>
      <span>·</span>
      <a href="/element-snap/privacy">Privacy Policy</a>
      <p>Element Snap is not affiliated with Google, Chrome, or Valve/Steam.</p>
    </footer>
  </div>
</BaseLayout>
